{
  "name": "bpmn-analyzer-js",
  "version": "0.0.1",
  "description": "bpmn-js including analysis after each save",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "all": "run-s lint pCheck test:run build",
    "build": "vite build",
    "lint": "eslint .",
    "start": "vite",
    "dev": "vite",
    "preview": "vite preview",
    "build:gh-pages": "vite build --mode ghPages",
    "build:rust": "vite build --mode rust",
    "pCheck": "prettier . --check",
    "pWrite": "prettier . --write",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test"
  },
  "author": {
    "name": "Tim Kräuter",
    "url": "https://timkraeuter.com/"
  },
  "files": [
    "src",
    "index.js"
  ],
  "engines": {
    "node": ">= 20.19.0"
  },
  "sideEffects": [
    "*.css"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "bpmn-js": "^18.16.1",
    "diagram-js": "^15.18.0",
    "min-dash": "^5.0.0",
    "min-dom": "^5.3.0",
    "randomcolor": "^0.6.2",
    "tiny-svg": "^4.1.4"
  }
}
